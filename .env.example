# ============================================
# RFQ Automation System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- App ---
APP_NAME=RFQ Automation System
DEBUG=true
SECRET_KEY=change-me-to-a-random-string

# --- Database ---
DATABASE_URL=sqlite:///./rfq_automation.db

# --- LLM (NVIDIA NIM / OpenAI-compatible) ---
OPENAI_API_KEY=nvapi-your-nvidia-nim-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=openai/gpt-oss-120b

# --- SMTP (Outgoing Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=RFQ Automation System
SMTP_USE_TLS=true

# --- IMAP (Incoming Email) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_SECONDS=60

# --- Redis (for Celery) ---
# Khi chạy bằng Docker Compose: dùng redis://redis:6379/0
# Khi chạy local (không Docker): dùng redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Currency Exchange ---
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_BASE_URL=https://v6.exchangerate-api.com/v6

SENDER_NAME=
SENDER_POSITION=
SENDER_COMPANY=
SENDER_PHONE=